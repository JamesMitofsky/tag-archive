# Drizzle / Turso
#
# LOCAL DEV: talk to the DB over a libsql URL (served by `turso dev`), like prod —
# not a raw file, so nothing double-writes the SQLite file. `pnpm dev:local` /
# `pnpm dev:db` start sqld on this port; the Conductor run injects it per-workspace.
DATABASE_URL="http://127.0.0.1:8081"
# Offline escape hatch for one-off scripts with no sqld running: DATABASE_URL="file:local.db"
#
# PRODUCTION: point at remote Turso and set the auth token.
# DATABASE_URL="libsql://db-name-user.turso.io"
# An auth token is required for remote (libsql:// / https://) URLs only.
DATABASE_AUTH_TOKEN=""

ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32 characters generated with high entropy.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="dev-secret-change-me"

# Resend (OTP email delivery). When unset, one-time codes are logged to the
# server console instead — fine for local dev.
RESEND_API_KEY=""
# Verified sender, e.g. "TAG Archive <archive@yourdomain.org>".
# Falls back to onboarding@resend.dev (delivers only to the Resend account
# owner's email until a domain is verified).
RESEND_FROM=""

# Scan storage (S3-compatible). These defaults target the LOCAL RustFS container
# that `pnpm dev:local` starts — copy this file to .env and they just work.
# `S3_ENDPOINT` + `R2_PUBLIC_URL` are injected by the run scripts (per-workspace
# ports), so they're intentionally left unset here.
R2_ACCESS_KEY_ID="rustfsadmin"
R2_SECRET_ACCESS_KEY="rustfsadmin"
R2_BUCKET="tag-archive"
S3_REGION="auto"
#
# PRODUCTION uses Cloudflare R2 instead — do NOT put prod keys here. Set these in
# Netlify → Environment variables (and .env.production for `vite preview`):
#   R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET, R2_PUBLIC_URL
# Create an R2 bucket, enable its Public Development URL, and mint an
# "Object Read & Write" API token (account id is in the S3 endpoint host).
