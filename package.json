{
	"name": "bangui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:local": "bash scripts/dev-local.sh",
		"dev:fresh-start": "pnpm db:setup:local && pnpm dev:local",
		"dev:db": "turso dev --db-file local.db --port 8081",
		"dev:storage": "docker rm -f tag-archive-rustfs >/dev/null 2>&1; docker run --rm --name tag-archive-rustfs -p 9000:9000 -e RUSTFS_ACCESS_KEY=rustfsadmin -e RUSTFS_SECRET_KEY=rustfsadmin -e RUSTFS_ADDRESS=:9000 rustfs/rustfs:latest /data",
		"dev:storage:init": "S3_ENDPOINT=http://127.0.0.1:9000 R2_PUBLIC_URL=http://127.0.0.1:9000/tag-archive node --env-file-if-exists=.env scripts/init-bucket.mjs",
		"db:seed:images": "S3_ENDPOINT=http://127.0.0.1:9000 R2_PUBLIC_URL=http://127.0.0.1:9000/tag-archive DATABASE_URL=http://127.0.0.1:8081 node --env-file-if-exists=.env scripts/seed-images.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && husky || echo ''",
		"prettier": "prettier --check .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:e2e": "playwright install && playwright test",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:unit": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/lib/server/db/migrate.ts",
		"db:migrate:test": "bash scripts/migrate-test.sh",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx src/lib/server/db/seed.ts",
		"db:import": "tsx src/lib/server/db/import-archive.ts",
		"db:setup:local": "bash scripts/db-setup.sh",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@libsql/client": "^0.17.3",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "10.5.0",
		"@storybook/addon-docs": "10.5.0",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "10.5.0",
		"@storybook/sveltekit": "10.5.0",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"better-auth": "~1.4.21",
		"bits-ui": "^2.18.1",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"mdsvex": "^0.12.7",
		"phosphor-svelte": "^3.1.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "10.5.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.111.0",
		"zod": "^4.4.3"
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"@tanstack/svelte-virtual": "3.13.32",
		"aws4fetch": "^1.0.20",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0",
		"vest": "^6.3.2"
	}
}
